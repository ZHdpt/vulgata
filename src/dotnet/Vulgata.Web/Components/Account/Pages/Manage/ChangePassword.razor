@page "/Account/Manage/ChangePassword"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Vulgata.Web.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ChangePassword> Logger

<PageTitle>修改密码</PageTitle>

<h3>修改密码</h3>
<StatusMessage Message="@message" />
@if (!string.IsNullOrEmpty(validationError))
{
    <div class="alert alert-danger" role="alert">@validationError</div>
}
<div class="row">
    <div class="col-xl-6">
        <EditForm Model="Input" FormName="change-password" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            <FluentTextField
                @bind-Value="Input.OldPassword"
                id="Input.OldPassword"
                type="password"
                autocomplete="current-password"
                aria-required="true"
                placeholder="请输入当前密码"
                Label="当前密码" />
            <ValidationMessage For="() => Input.OldPassword" class="text-danger" />

            <FluentTextField
                @bind-Value="Input.NewPassword"
                id="Input.NewPassword"
                type="password"
                autocomplete="new-password"
                aria-required="true"
                placeholder="请输入新密码"
                Label="新密码" />
            <ValidationMessage For="() => Input.NewPassword" class="text-danger" />

            <FluentTextField
                @bind-Value="Input.ConfirmPassword"
                id="Input.ConfirmPassword"
                type="password"
                autocomplete="new-password"
                aria-required="true"
                placeholder="请再次输入新密码"
                Label="确认新密码" />
            <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />

            <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Class="w-100">更新密码</FluentButton>
        </EditForm>
    </div>
</div>

@code {
    private string? message;
    private string? validationError;
    private ApplicationUser? user;
    private bool hasPassword;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        hasPassword = await UserManager.HasPasswordAsync(user);
        if (!hasPassword)
        {
            RedirectManager.RedirectTo("Account/Manage/SetPassword");
        }
    }

    private async Task OnValidSubmitAsync()
    {
        message = null;
        validationError = null;

        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        if (!await UserManager.CheckPasswordAsync(user, Input.OldPassword))
        {
            validationError = "当前密码不正确";
            return;
        }

        IdentityResult changePasswordResult = await UserManager.ChangePasswordAsync(user, Input.OldPassword, Input.NewPassword);
        if (!changePasswordResult.Succeeded)
        {
            message = $"错误：{string.Join("，", changePasswordResult.Errors.Select(error => error.Description))}";
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        Logger.LogInformation("User changed their password successfully.");

        RedirectManager.RedirectToCurrentPageWithStatus("您的密码已修改。", HttpContext);
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "当前密码字段是必需的。")]
        [DataType(DataType.Password)]
        [Display(Name = "当前密码")]
        public string OldPassword { get; set; } = "";

        [Required(ErrorMessage = "新密码字段是必需的。")]
        [StringLength(100, ErrorMessage = "{0}长度必须在 {2} 到 {1} 之间。", MinimumLength = 8)]
        [DataType(DataType.Password)]
        [Display(Name = "新密码")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "确认新密码字段是必需的。")]
        [DataType(DataType.Password)]
        [Display(Name = "确认新密码")]
        [Compare("NewPassword", ErrorMessage = "密码与确认密码不一致。")]
        public string ConfirmPassword { get; set; } = "";
    }
}
