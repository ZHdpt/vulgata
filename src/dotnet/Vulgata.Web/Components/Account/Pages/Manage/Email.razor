@page "/Account/Manage/Email"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Vulgata.Web.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>管理邮箱</PageTitle>

<h3>管理邮箱</h3>

<StatusMessage Message="@message" />
@if (!string.IsNullOrEmpty(validationError))
{
    <div class="alert alert-danger" role="alert">@validationError</div>
}
<div class="row">
    <div class="col-xl-6">
        <EditForm Model="Input" FormName="change-email" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            <FluentTextField
                Value="@email"
                id="email"
                ReadOnly="true"
                Label="当前邮箱" />

            <FluentTextField
                @bind-Value="Input.NewEmail"
                id="Input.NewEmail"
                autocomplete="email"
                aria-required="true"
                placeholder="请输入新邮箱"
                Label="新邮箱" />
            <ValidationMessage For="() => Input.NewEmail" class="text-danger" />

            <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Class="w-100">更改邮箱</FluentButton>
        </EditForm>
    </div>
</div>

@code {
    private string? message;
    private string? validationError;
    private ApplicationUser? user;
    private string? email;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "change-email")]
    private InputModel Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        email = await UserManager.GetEmailAsync(user);
        Input.NewEmail ??= email;
    }

    private async Task OnValidSubmitAsync()
    {
        message = null;
        validationError = null;

        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        string newEmail = Input.NewEmail?.Trim() ?? string.Empty;
        if (string.Equals(newEmail, email, StringComparison.OrdinalIgnoreCase))
        {
            message = "邮箱未发生变化。";
            return;
        }

        string? originalEmail = user.Email;
        string? originalUserName = user.UserName;
        bool originalEmailConfirmed = user.EmailConfirmed;

        user.Email = newEmail;
        user.UserName = newEmail;
        user.EmailConfirmed = true;

        IdentityResult updateResult = await UserManager.UpdateAsync(user);
        if (!updateResult.Succeeded)
        {
            user.Email = originalEmail;
            user.UserName = originalUserName;
            user.EmailConfirmed = originalEmailConfirmed;

            IdentityError[] errors = FilterEmailUpdateErrors(updateResult.Errors).ToArray();
            validationError = errors.FirstOrDefault(error => error.Code == nameof(IdentityErrorDescriber.DuplicateEmail))?.Description;
            if (validationError is null)
            {
                message = $"错误：{string.Join("，", errors.Select(error => error.Description))}";
            }

            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        email = newEmail;
        Input.NewEmail = newEmail;
        message = "邮箱已更新。";
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "新邮箱字段是必需的。")]
        [EmailAddress(ErrorMessage = "新邮箱字段不是有效的电子邮件地址。")]
        [Display(Name = "新邮箱")]
        public string? NewEmail { get; set; }
    }

    private static IEnumerable<IdentityError> FilterEmailUpdateErrors(IEnumerable<IdentityError> errors)
    {
        IdentityError[] materializedErrors = errors.ToArray();

        if (!materializedErrors.Any(error => error.Code == nameof(IdentityErrorDescriber.DuplicateEmail)))
        {
            return materializedErrors;
        }

        return materializedErrors.Where(error => error.Code != nameof(IdentityErrorDescriber.DuplicateUserName));
    }
}
