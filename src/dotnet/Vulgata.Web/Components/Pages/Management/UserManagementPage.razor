@page "/management/settings/users"
@layout ManagementLayout
@attribute [Authorize(Policy = AuthorizationPolicyNames.AdministratorOnly)]

@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@using Vulgata.Web.Data

@inject UserManager<ApplicationUser> UserManager
@inject IAdministratorRoleCoordinator AdministratorRoleCoordinator
@inject IServiceScopeFactory ScopeFactory

<PageTitle>用户管理</PageTitle>

<h1 class="display-serif display-serif-sm">用户管理</h1>
<p>管理员可以在此授予或移除管理员权限。</p>

@if (!string.IsNullOrEmpty(_statusMessage))
{
    var statusClass = _isStatusError ? "danger" : "success";
    <div class="alert alert-@statusClass" role="alert">
        @_statusMessage
    </div>
}

@if (_rows.Count == 0)
{
    <p>暂无注册用户。</p>
}
else
{
    <table class="table" aria-label="用户和角色列表">
        <thead>
            <tr>
                <th scope="col">邮箱</th>
                <th scope="col">角色</th>
                <th scope="col">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (UserRoleRow row in _rows)
            {
                <tr>
                    <td>@row.Email</td>
                    <td>@string.Join(", ", row.Roles)</td>
                    <td>
                        @if (row.IsAdministrator)
                        {
                            if (row.CanRemoveAdministrator)
                            {
                                <FluentButton Appearance="Appearance.Neutral"
                                              OnClick="@(async () => await RemoveAdministratorAsync(row.UserId))" disabled="@_isProcessing">
                                    移除管理员
                                </FluentButton>
                            }
                            else
                            {
                                <span class="text-muted">至少需要保留一名管理员</span>
                            }
                        }
                        else
                        {
                            <FluentButton Appearance="Appearance.Accent"
                                          OnClick="@(async () => await GrantAdministratorAsync(row.UserId))" disabled="@_isProcessing">
                                授予管理员
                            </FluentButton>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<UserRoleRow> _rows = [];
    private string? _statusMessage;
    private bool _isStatusError;
    private bool _isProcessing;

    protected override async Task OnInitializedAsync()
    {
        await LoadRowsAsync();
    }

    private async Task GrantAdministratorAsync(string userId)
    {
        _isProcessing = true;
        _statusMessage = null;
        _isStatusError = false;

        try
        {
            ApplicationUser? user = await UserManager.FindByIdAsync(userId);
            if (user is null)
            {
                SetStatus("错误：未找到指定用户。", isError: true);
                return;
            }

            if (await UserManager.IsInRoleAsync(user, RoleNames.Administrator))
            {
                SetStatus("该用户已是管理员。");
                return;
            }

            IdentityResult result = await UserManager.AddToRoleAsync(user, RoleNames.Administrator);
            if (!result.Succeeded)
            {
                SetStatus(BuildErrorMessage(result.Errors), isError: true);
                return;
            }

            SetStatus("已授予管理员权限。");
            await LoadRowsAsync();
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RemoveAdministratorAsync(string userId)
    {
        _isProcessing = true;
        _statusMessage = null;
        _isStatusError = false;

        try
        {
            ApplicationUser? user = await UserManager.FindByIdAsync(userId);
            if (user is null)
            {
                SetStatus("错误：未找到指定用户。", isError: true);
                return;
            }

            AdministratorRoleRemovalResult result = await AdministratorRoleCoordinator.RemoveAdministratorAsync(user);
            switch (result.Outcome)
            {
                case AdministratorRoleRemovalOutcome.NotAdministrator:
                    SetStatus("该用户当前不是管理员。");
                    return;
                case AdministratorRoleRemovalOutcome.LastAdministratorBlocked:
                    SetStatus("错误：至少需要保留一名管理员。", isError: true);
                    return;
                case AdministratorRoleRemovalOutcome.Failed:
                    SetStatus(BuildErrorMessage(result.IdentityResult?.Errors ?? []), isError: true);
                    return;
                default:
                    SetStatus("已移除管理员权限。");
                    await LoadRowsAsync();
                    return;
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void SetStatus(string message, bool isError = false)
    {
        _statusMessage = isError && !message.StartsWith("错误：", StringComparison.Ordinal)
            ? $"错误：{message}"
            : message;
        _isStatusError = isError;
    }

    private async Task LoadRowsAsync()
    {
        // Resolve a fresh UserManager from an isolated scope to prevent DbContext
        // concurrency when Npgsql's EnableRetryOnFailure retries overlap with
        // the next query on the same ApplicationDbContext instance.
        await using AsyncServiceScope scope = ScopeFactory.CreateAsyncScope();
        UserManager<ApplicationUser> scopedUserManager =
            scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();

        List<ApplicationUser> users = await scopedUserManager.Users
            .OrderBy(user => user.Email)
            .ThenBy(user => user.UserName)
            .ToListAsync();

        IList<ApplicationUser> administrators =
            await scopedUserManager.GetUsersInRoleAsync(RoleNames.Administrator);
        bool canRemoveAdministrator = administrators.Count > 1;

        List<UserRoleRow> rows = [];
        foreach (ApplicationUser user in users)
        {
            IList<string> roles = await scopedUserManager.GetRolesAsync(user);
            string[] orderedRoles = roles
                .OrderBy(GetRolePriority)
                .ThenBy(role => role, StringComparer.Ordinal)
                .ToArray();

            bool isAdministrator = orderedRoles.Contains(RoleNames.Administrator, StringComparer.Ordinal);
            rows.Add(new UserRoleRow(
                user.Id,
                user.Email ?? user.UserName ?? "(未命名用户)",
                orderedRoles.Length == 0 ? ["(无角色)"] : orderedRoles,
                isAdministrator,
                isAdministrator && canRemoveAdministrator));
        }

        _rows = rows;
    }

    private static int GetRolePriority(string roleName) => roleName switch
    {
        RoleNames.Administrator => 0,
        RoleNames.SystemOwner => 1,
        RoleNames.User => 2,
        _ => 3,
    };

    private static string BuildErrorMessage(IEnumerable<IdentityError> errors)
    {
        string details = string.Join("；", errors.Select(error => error.Description));
        return string.IsNullOrWhiteSpace(details)
            ? "错误：角色变更失败，请稍后重试。"
            : $"错误：{details}";
    }

    private sealed record UserRoleRow(
        string UserId,
        string Email,
        IReadOnlyList<string> Roles,
        bool IsAdministrator,
        bool CanRemoveAdministrator);
}
