@page "/management"
@layout ManagementLayout
@attribute [Authorize(Policy = AuthorizationPolicyNames.ManagementAccess)]
@rendermode InteractiveServer
@using System.Security.Claims
@using FluentValidation
@using FluentValidation.Results
@using Vulgata.Core.DomainServices
@using Vulgata.Core.Entities
@using Vulgata.Shared.Repositories
@using Vulgata.Web.Data
@using Vulgata.Web.Validators
@using SystemEntity = Vulgata.Core.Entities.System

@inject ISystemRepository SystemRepository
@inject IRepositoryManagementCoordinator RepositoryManagementCoordinator
@inject IRepositoryDatabaseConnectionCoordinator RepositoryDatabaseConnectionCoordinator
@inject ISystemLlmProviderOverrideCoordinator SystemLlmProviderOverrideCoordinator
@inject IValidator<CreateRepositoryRequest> RepositoryRequestValidator
@inject IValidator<UpsertDatabaseConnectionRequest> DatabaseConnectionValidator
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>系统管理</PageTitle>

<h1 class="display-serif display-serif-sm">系统管理</h1>
<p>在仓库详情中可维护数据库连接并执行测试连接。</p>

@if (_loadError is not null)
{
    <FluentMessageBar Severity="MessageSeverity.Error">@_loadError</FluentMessageBar>
}

@if (_systems is null)
{
    <FluentProgressRing />
}
else
{
    <section style="margin-bottom:1.5rem">
        <h2 style="margin-top:1.5rem">独立仓库</h2>
        <p>不归属于任何系统，所有具备管理权限的用户都可见。</p>

        <table class="table" aria-label="独立仓库列表">
            <thead>
                <tr>
                    <th scope="col">仓库名称</th>
                    <th scope="col">扫描状态</th>
                    <th scope="col">最近扫描时间</th>
                    <th scope="col">文档数量</th>
                    <th scope="col">查看</th>
                </tr>
            </thead>
            <tbody>
                @if (_standaloneRepositories.Count > 0)
                {
                    @foreach (RepositorySummaryDto repository in _standaloneRepositories)
                    {
                        <tr>
                            <td>@repository.Name</td>
                            <td>@repository.ScanStatus</td>
                            <td>@(repository.LastScannedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>@repository.DocumentCount</td>
                            <td>
                                <FluentButton Appearance="Appearance.Neutral" Size="Size.Small"
                                              OnClick="@(() => OpenRepositoryDetailAsync(repository))">查看</FluentButton>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">暂无独立仓库</td>
                    </tr>
                }
            </tbody>
        </table>

        <FluentButton Appearance="Appearance.Accent" Size="Size.Small"
                      OnClick="StartCreateStandaloneRepository" Style="margin-bottom:0.5rem">+ 新建独立仓库</FluentButton>
    </section>

    @if (_systems.Count == 0)
    {
        <p>尚未添加任何系统。创建你的第一个系统开始扫描。</p>
    }
    else
    {
        @foreach (SystemEntity system in _systems)
        {
            <h2 style="margin-top:1.5rem">@system.Name</h2>
            @if (!string.IsNullOrWhiteSpace(system.Description))
            {
                <p>@system.Description</p>
            }
            @if (_isAdministrator)
            {
                <div style="margin-bottom:0.5rem">
                    <FluentButton Appearance="Appearance.Neutral" Size="Size.Small"
                                  OnClick="@(() => StartEditSystem(system))">编辑</FluentButton>
                    <FluentButton Appearance="Appearance.Neutral" Size="Size.Small"
                                  OnClick="@(() => OpenOwnerManagement(system))">管理所有者</FluentButton>
                    <FluentButton Appearance="Appearance.Accent" Size="Size.Small"
                                  OnClick="@(() => DeleteSystemAsync(system))">删除</FluentButton>
                </div>
            }

            <table class="table" aria-label="@system.Name 仓库列表">
                <thead>
                    <tr>
                        <th scope="col">仓库名称</th>
                        <th scope="col">扫描状态</th>
                        <th scope="col">最近扫描时间</th>
                        <th scope="col">文档数量</th>
                        <th scope="col">查看</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_repositories.TryGetValue(system.Id, out List<RepositorySummaryDto>? repositories) && repositories.Count > 0)
                    {
                        @foreach (RepositorySummaryDto repository in repositories)
                        {
                            <tr>
                                <td>@repository.Name</td>
                                <td>@repository.ScanStatus</td>
                                <td>@(repository.LastScannedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td>@repository.DocumentCount</td>
                                <td>
                                    <FluentButton Appearance="Appearance.Neutral" Size="Size.Small"
                                                  OnClick="@(() => OpenRepositoryDetailAsync(repository))">查看</FluentButton>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">暂无仓库</td>
                        </tr>
                    }
                </tbody>
            </table>

            <FluentButton Appearance="Appearance.Accent" Size="Size.Small"
                          OnClick="@(() => StartCreateRepository(system))" Style="margin-bottom:0.5rem">+ 新建仓库</FluentButton>

            <section style="margin-bottom:1rem">
                <h3 style="margin-top:0.75rem">LLM Provider 覆盖</h3>
                <table class="table" aria-label="@system.Name LLM Provider 覆盖列表">
                    <thead>
                        <tr>
                            <th scope="col">代理角色</th>
                            <th scope="col">当前 Provider</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (AgentType agentType in Enum.GetValues<AgentType>())
                        {
                            SystemLlmProviderOverrideSummaryDto? overrideItem = GetSystemOverride(system.Id, agentType);
                            <tr>
                                <td>@GetAgentTypeDisplayName(agentType)</td>
                                <td>@(overrideItem?.ProviderName ?? "使用全局默认提供商")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }
    }
}

@if (_isAdministrator)
{
    <FluentButton Appearance="Appearance.Accent" OnClick="StartCreateSystem" Style="margin-top:1rem">+ 新建系统</FluentButton>
}

@if (_pendingDeleteSystem is not null)
{
    <FluentDialog @bind-Visible="_showDeleteConfirmation" Title="确认删除"
                  PrimaryActionText="确认删除" SecondaryActionText="取消"
                  PrimaryAction="@(async () => await ConfirmDeleteAsync())"
                  SecondaryAction="CancelDelete">
        <p>确定要删除系统 <strong>@_pendingDeleteSystem.Name</strong> 吗？此操作不可撤销。</p>
    </FluentDialog>
}

@if (_showForm)
{
    <hr />
    <h2>@(_editingSystem is null ? "新建系统" : "编辑系统")</h2>

    <EditForm Model="@_formModel" OnValidSubmit="SaveSystemAsync" FormName="system-form">
        <FluentValidationValidator />

        <FluentTextField @bind-Value="_formModel.Name" Label="系统名称" Required="true" />
        <FluentValidationMessage For="@(() => _formModel.Name)" />

        <FluentTextField @bind-Value="_formModel.Description" Label="系统描述" />
        <FluentValidationMessage For="@(() => _formModel.Description)" />

        <FluentTextArea @bind-Value="_formModel.Context" Label="补充上下文" Rows="4" />
        <FluentValidationMessage For="@(() => _formModel.Context)" />

        @if (_saveError is not null)
        {
            <FluentMessageBar Severity="MessageSeverity.Error">@_saveError</FluentMessageBar>
        }

        <div style="margin-top:1rem">
            <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit"
                          Disabled="@_isSaving">保存</FluentButton>
            <FluentButton Appearance="Appearance.Neutral" OnClick="CancelForm">取消</FluentButton>
        </div>
    </EditForm>
}

@if (_showRepositoryForm)
{
    <FluentDialog @bind-Visible="_showRepositoryForm" Title="新建仓库"
                  PrimaryActionText="创建" SecondaryActionText="取消"
                  PrimaryAction="@(async () => await CreateRepositoryAsync())"
                  SecondaryAction="CancelRepositoryForm">
        <EditForm Model="@_repoFormModel" FormName="repository-form">
            <FluentTextField @bind-Value="_repoFormModel.Name" Label="仓库名称" Required="true" />
            <FluentValidationMessage For="@(() => _repoFormModel.Name)" />

            <FluentTextField @bind-Value="_repoFormModel.GitUrl" Label="Git 远程地址" Required="true" />
            <FluentValidationMessage For="@(() => _repoFormModel.GitUrl)" />

            <FluentTextField @bind-Value="_repoFormModel.Description" Label="仓库描述" />
            <FluentValidationMessage For="@(() => _repoFormModel.Description)" />

            <FluentTextArea @bind-Value="_repoFormModel.Context" Label="补充上下文" Rows="3" />
            <FluentValidationMessage For="@(() => _repoFormModel.Context)" />

            @if (_repoError is not null)
            {
                <FluentMessageBar Severity="MessageSeverity.Error">@_repoError</FluentMessageBar>
            }
        </EditForm>
    </FluentDialog>
}

@if (_showRepositoryDetail && _selectedRepository is not null)
{
    <FluentDialog @bind-Visible="_showRepositoryDetail" Title="仓库详情"
                  PrimaryActionText="保存" SecondaryActionText="关闭"
                  PrimaryAction="@(async () => await SaveDatabaseConnectionAsync())"
                  SecondaryAction="CloseRepositoryDetail">
        <div style="display:grid;gap:0.75rem">
            <div><strong>仓库名称：</strong>@_selectedRepository.Name</div>

            <section style="padding:0.5rem 0;border-top:1px solid #d6d6d6">
                <h3 style="margin:0 0 0.5rem 0">数据库连接</h3>
                <div><strong>状态：</strong>@(_selectedRepositoryDatabaseConnection?.IsConfigured == true ? "已配置" : "未配置")</div>
                <div><strong>数据库类型：</strong>@GetDatabaseTypeDisplayName(_selectedRepositoryDatabaseConnection?.DatabaseType)</div>
                <div><strong>连接字符串：</strong>@(_selectedRepositoryDatabaseConnection?.HasConnectionString == true ? "已配置" : "未配置")</div>
                <div><strong>用户名：</strong>@(_selectedRepositoryDatabaseConnection?.HasUsername == true ? "已配置" : "未配置")</div>
                <div><strong>密码：</strong>@(_selectedRepositoryDatabaseConnection?.HasPassword == true ? "已配置" : "未配置")</div>
                <div><strong>最后更新时间：</strong>@(_selectedRepositoryDatabaseConnection?.UpdatedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
            </section>

            @if (_databaseConnectionError is not null)
            {
                <FluentMessageBar Severity="MessageSeverity.Error">@_databaseConnectionError</FluentMessageBar>
            }

            @if (_databaseConnectionStatus is not null)
            {
                <FluentMessageBar Severity="MessageSeverity.Success">@_databaseConnectionStatus</FluentMessageBar>
            }

            <div>
                <label for="database-type" style="display:block;margin-bottom:0.5rem">数据库类型</label>
                <InputSelect id="database-type" @bind-Value="_databaseConnectionForm.DatabaseType" class="form-select">
                    <option value="@DatabaseType.PostgreSql">PostgreSQL</option>
                    <option value="@DatabaseType.SqlServer">SqlServer</option>
                    <option value="@DatabaseType.MySql">MySql</option>
                    <option value="@DatabaseType.Sqlite">Sqlite</option>
                    <option value="@DatabaseType.Oracle">Oracle</option>
                    <option value="@DatabaseType.Other">Other</option>
                </InputSelect>
            </div>

            <FluentTextField @bind-Value="_databaseConnectionForm.ConnectionString" Label="连接字符串" Required="true" />
            <FluentTextField @bind-Value="_databaseConnectionForm.Username" Label="用户名（留空则保留现有值）" />
            <FluentTextField @bind-Value="_databaseConnectionForm.Password" Label="密码（留空则保留现有值）" type="password" />

            <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
                <FluentButton Appearance="Appearance.Neutral" Size="Size.Small"
                              Disabled="@_isDatabaseConnectionBusy"
                              OnClick="@(async () => await TestDatabaseConnectionAsync())">测试连接</FluentButton>
                <FluentButton Appearance="Appearance.Accent" Size="Size.Small"
                              Disabled="@_isDatabaseConnectionBusy"
                              OnClick="@(async () => await DeleteDatabaseConnectionAsync())">删除</FluentButton>
            </div>
        </div>
    </FluentDialog>
}

@if (_showStandaloneRepositoryForm)
{
    <FluentDialog @bind-Visible="_showStandaloneRepositoryForm" Title="新建独立仓库"
                  PrimaryActionText="创建" SecondaryActionText="取消"
                  PrimaryAction="@(async () => await CreateStandaloneRepositoryAsync())"
                  SecondaryAction="CancelStandaloneRepositoryForm">
        <EditForm Model="@_standaloneRepoFormModel" FormName="standalone-repository-form">
            <p>该仓库不属于任何系统，所有具备管理权限的用户都可见。</p>

            <FluentTextField @bind-Value="_standaloneRepoFormModel.Name" Label="仓库名称" Required="true" />
            <FluentValidationMessage For="@(() => _standaloneRepoFormModel.Name)" />

            <FluentTextField @bind-Value="_standaloneRepoFormModel.GitUrl" Label="Git 远程地址" Required="true" />
            <FluentValidationMessage For="@(() => _standaloneRepoFormModel.GitUrl)" />

            <FluentTextField @bind-Value="_standaloneRepoFormModel.Description" Label="仓库描述" />
            <FluentValidationMessage For="@(() => _standaloneRepoFormModel.Description)" />

            <FluentTextArea @bind-Value="_standaloneRepoFormModel.Context" Label="补充上下文" Rows="3" />
            <FluentValidationMessage For="@(() => _standaloneRepoFormModel.Context)" />

            @if (_standaloneRepoError is not null)
            {
                <FluentMessageBar Severity="MessageSeverity.Error">@_standaloneRepoError</FluentMessageBar>
            }
        </EditForm>
    </FluentDialog>
}

@if (_ownerManagementSystem is not null)
{
    <ManageSystemOwnersDialog
        SystemId="_ownerManagementSystem.Id"
        SystemName="_ownerManagementSystem.Name"
        Visible="_showOwnerManagement"
        VisibleChanged="OnOwnerManagementVisibilityChanged" />
}

@code {
    private List<SystemEntity>? _systems;
    private Dictionary<Guid, List<RepositorySummaryDto>> _repositories = [];
    private Dictionary<Guid, List<SystemLlmProviderOverrideSummaryDto>> _systemLlmOverrides = [];
    private List<RepositorySummaryDto> _standaloneRepositories = [];
    private string? _loadError;
    private string? _saveError;
    private string? _repoError;
    private string? _standaloneRepoError;
    private string? _databaseConnectionError;
    private string? _databaseConnectionStatus;
    private bool _isAdministrator;
    private bool _isSaving;
    private bool _isDatabaseConnectionBusy;
    private bool _showForm;
    private bool _showRepositoryForm;
    private bool _showStandaloneRepositoryForm;
    private bool _showRepositoryDetail;
    private SystemEntity? _editingSystem;

    private string _userId = string.Empty;

    private CreateSystemRequest _formModel = new();
    private CreateRepositoryRequest _repoFormModel = new();
    private CreateRepositoryRequest _standaloneRepoFormModel = new();
    private UpsertDatabaseConnectionRequest _databaseConnectionForm = new();
    private RepositorySummaryDto? _selectedRepository;
    private RepositoryDatabaseConnectionSummaryDto? _selectedRepositoryDatabaseConnection;
    private SystemEntity? _repoTargetSystem;

    private SystemEntity? _pendingDeleteSystem;
    private bool _showDeleteConfirmation;
    private SystemEntity? _ownerManagementSystem;
    private bool _showOwnerManagement;

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        ClaimsPrincipal user = authState.User;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        _isAdministrator = user.IsInRole(RoleNames.Administrator);

        await LoadSystemsAsync();
    }

    private async Task LoadSystemsAsync()
    {
        try
        {
            _loadError = null;
            _systems = (await SystemRepository.ListVisibleAsync(_userId, _isAdministrator)).ToList();
            _standaloneRepositories = (await RepositoryManagementCoordinator
                .ListStandaloneVisibleAsync(_userId, _isAdministrator))
                .ToList();
            _repositories = [];
            _systemLlmOverrides = [];

            foreach (SystemEntity system in _systems)
            {
                IReadOnlyList<RepositorySummaryDto> repositories = await RepositoryManagementCoordinator.ListVisibleAsync(
                    system.Id,
                    _userId,
                    _isAdministrator);
                _repositories[system.Id] = repositories.ToList();

                SystemLlmProviderOverrideMutationResult<IReadOnlyList<SystemLlmProviderOverrideSummaryDto>> overridesResult =
                    await SystemLlmProviderOverrideCoordinator.ListAsync(system.Id, _userId, _isAdministrator);

                _systemLlmOverrides[system.Id] =
                    overridesResult.Outcome == SystemLlmProviderOverrideMutationOutcome.Success && overridesResult.Value is not null
                        ? overridesResult.Value.ToList()
                        : [];
            }
        }
        catch (Exception ex)
        {
            _loadError = $"加载系统列表失败：{ex.Message}";
            _systems = [];
            _standaloneRepositories = [];
            _repositories = [];
            _systemLlmOverrides = [];
        }
    }

    private async Task ReloadRepositoriesAsync(Guid systemId)
    {
        IReadOnlyList<RepositorySummaryDto> repositories = await RepositoryManagementCoordinator.ListVisibleAsync(
            systemId,
            _userId,
            _isAdministrator);
        _repositories[systemId] = repositories.ToList();
    }

    private async Task ReloadStandaloneRepositoriesAsync()
    {
        IReadOnlyList<RepositorySummaryDto> repositories = await RepositoryManagementCoordinator.ListStandaloneVisibleAsync(
            _userId,
            _isAdministrator);
        _standaloneRepositories = repositories.ToList();
    }

    private void StartCreateSystem()
    {
        _editingSystem = null;
        _formModel = new CreateSystemRequest();
        _saveError = null;
        _showForm = true;
    }

    private void StartEditSystem(SystemEntity system)
    {
        _editingSystem = system;
        _formModel = new CreateSystemRequest
        {
            Name = system.Name,
            Description = system.Description,
            Context = system.Context,
        };
        _saveError = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _editingSystem = null;
        _saveError = null;
    }

    private void StartCreateRepository(SystemEntity system)
    {
        _repoTargetSystem = system;
        _repoFormModel = new CreateRepositoryRequest();
        _repoError = null;
        _showRepositoryForm = true;
    }

    private void CancelRepositoryForm()
    {
        _showRepositoryForm = false;
        _repoTargetSystem = null;
        _repoFormModel = new CreateRepositoryRequest();
        _repoError = null;
    }

    private void StartCreateStandaloneRepository()
    {
        _standaloneRepoFormModel = new CreateRepositoryRequest();
        _standaloneRepoError = null;
        _showStandaloneRepositoryForm = true;
    }

    private void CancelStandaloneRepositoryForm()
    {
        _showStandaloneRepositoryForm = false;
        _standaloneRepoFormModel = new CreateRepositoryRequest();
        _standaloneRepoError = null;
    }

    private async Task OpenRepositoryDetailAsync(RepositorySummaryDto repository)
    {
        _selectedRepository = repository;
        _showRepositoryDetail = true;
        _databaseConnectionError = null;
        _databaseConnectionStatus = null;
        _databaseConnectionForm = new UpsertDatabaseConnectionRequest
        {
                DatabaseType = DatabaseType.PostgreSql,
            ConnectionString = string.Empty,
            Username = string.Empty,
            Password = string.Empty,
        };

        await ReloadSelectedRepositoryDatabaseConnectionAsync();
    }

    private void CloseRepositoryDetail()
    {
        _showRepositoryDetail = false;
        _selectedRepository = null;
        _selectedRepositoryDatabaseConnection = null;
        _databaseConnectionError = null;
        _databaseConnectionStatus = null;
        _databaseConnectionForm = new UpsertDatabaseConnectionRequest();
    }

    private async Task SaveDatabaseConnectionAsync()
    {
        if (_selectedRepository is null || _isDatabaseConnectionBusy)
        {
            return;
        }

        _databaseConnectionError = null;
        _databaseConnectionStatus = null;

        ValidationResult validationResult = await DatabaseConnectionValidator.ValidateAsync(_databaseConnectionForm);
        if (!validationResult.IsValid)
        {
            _databaseConnectionError = validationResult.Errors.Select(error => error.ErrorMessage).FirstOrDefault();
            return;
        }

        _isDatabaseConnectionBusy = true;

        try
        {
            RepositoryDatabaseConnectionMutationResult<RepositoryDatabaseConnectionSummaryDto> result =
                await RepositoryDatabaseConnectionCoordinator.UpsertAsync(
                    _selectedRepository.Id,
                    _databaseConnectionForm,
                    _userId,
                    _isAdministrator);

            if (result.Outcome == RepositoryDatabaseConnectionMutationOutcome.RepositoryNotFound || result.Value is null)
            {
                _databaseConnectionError = result.Message ?? "仓库不存在。";
                return;
            }

            _selectedRepositoryDatabaseConnection = result.Value;
            _databaseConnectionStatus = "数据库连接已保存。";
            _databaseConnectionForm.ConnectionString = string.Empty;
            _databaseConnectionForm.Username = string.Empty;
            _databaseConnectionForm.Password = string.Empty;
        }
        catch (Exception ex)
        {
            _databaseConnectionError = $"数据库连接保存失败：{ex.Message}";
        }
        finally
        {
            _isDatabaseConnectionBusy = false;
        }
    }

    private async Task DeleteDatabaseConnectionAsync()
    {
        if (_selectedRepository is null || _isDatabaseConnectionBusy)
        {
            return;
        }

        _isDatabaseConnectionBusy = true;
        _databaseConnectionError = null;
        _databaseConnectionStatus = null;

        try
        {
            RepositoryDatabaseConnectionMutationResult<bool> result =
                await RepositoryDatabaseConnectionCoordinator.DeleteAsync(
                    _selectedRepository.Id,
                    _userId,
                    _isAdministrator);

            if (result.Outcome == RepositoryDatabaseConnectionMutationOutcome.RepositoryNotFound)
            {
                _databaseConnectionError = result.Message ?? "仓库不存在。";
                return;
            }

            _selectedRepositoryDatabaseConnection = new RepositoryDatabaseConnectionSummaryDto
            {
                RepositoryId = _selectedRepository.Id,
                IsConfigured = false,
                HasConnectionString = false,
                HasUsername = false,
                HasPassword = false,
            };
            _databaseConnectionStatus = "数据库连接已删除。";
        }
        catch (Exception ex)
        {
            _databaseConnectionError = $"数据库连接删除失败：{ex.Message}";
        }
        finally
        {
            _isDatabaseConnectionBusy = false;
        }
    }

    private async Task TestDatabaseConnectionAsync()
    {
        if (_selectedRepository is null || _isDatabaseConnectionBusy)
        {
            return;
        }

        _isDatabaseConnectionBusy = true;
        _databaseConnectionError = null;
        _databaseConnectionStatus = null;

        try
        {
            RepositoryDatabaseConnectionTestResult result = await RepositoryDatabaseConnectionCoordinator.TestConnectionAsync(
                _selectedRepository.Id,
                _userId,
                _isAdministrator);

            if (result.Outcome == RepositoryDatabaseConnectionTestOutcome.Success)
            {
                _databaseConnectionStatus = result.Message;
                return;
            }

            _databaseConnectionError = result.Message;
        }
        catch (Exception ex)
        {
            _databaseConnectionError = $"连接测试失败：{ex.Message}";
        }
        finally
        {
            _isDatabaseConnectionBusy = false;
        }
    }

    private async Task ReloadSelectedRepositoryDatabaseConnectionAsync()
    {
        if (_selectedRepository is null)
        {
            _selectedRepositoryDatabaseConnection = null;
            return;
        }

        RepositoryDatabaseConnectionMutationResult<RepositoryDatabaseConnectionSummaryDto> result =
            await RepositoryDatabaseConnectionCoordinator.GetAsync(
                _selectedRepository.Id,
                _userId,
                _isAdministrator);

        if (result.Outcome == RepositoryDatabaseConnectionMutationOutcome.Success && result.Value is not null)
        {
            _selectedRepositoryDatabaseConnection = result.Value;
            if (result.Value.DatabaseType.HasValue)
            {
                _databaseConnectionForm.DatabaseType = (DatabaseType)result.Value.DatabaseType.Value;
            }
            return;
        }

        _selectedRepositoryDatabaseConnection = new RepositoryDatabaseConnectionSummaryDto
        {
            RepositoryId = _selectedRepository.Id,
            IsConfigured = false,
            HasConnectionString = false,
            HasUsername = false,
            HasPassword = false,
        };
    }

    private async Task CreateRepositoryAsync()
    {
        if (_repoTargetSystem is null)
        {
            return;
        }

        _repoError = await ValidateRepositoryRequestAsync(_repoFormModel);
        if (_repoError is not null)
        {
            return;
        }

        Guid systemId = _repoTargetSystem.Id;

        try
        {
            RepositoryMutationResult<RepositoryDetailDto> result = await RepositoryManagementCoordinator.CreateAsync(
                systemId,
                _repoFormModel,
                _userId,
                _isAdministrator);

            if (result.Outcome != RepositoryMutationOutcome.Success || result.Value is null)
            {
                _repoError = BuildRepositoryErrorMessage(result, "系统不存在或无权操作。");
                return;
            }

            _showRepositoryForm = false;
            _repoTargetSystem = null;
            _repoFormModel = new CreateRepositoryRequest();
            await ReloadRepositoriesAsync(systemId);
        }
        catch (Exception ex)
        {
            _repoError = $"创建仓库失败：{ex.Message}";
        }
    }

    private async Task CreateStandaloneRepositoryAsync()
    {
        _standaloneRepoError = await ValidateRepositoryRequestAsync(_standaloneRepoFormModel);
        if (_standaloneRepoError is not null)
        {
            return;
        }

        try
        {
            RepositoryMutationResult<RepositoryDetailDto> result = await RepositoryManagementCoordinator.CreateStandaloneAsync(
                _standaloneRepoFormModel,
                _userId,
                _isAdministrator);

            if (result.Outcome != RepositoryMutationOutcome.Success || result.Value is null)
            {
                _standaloneRepoError = BuildRepositoryErrorMessage(result, "独立仓库创建失败。");
                return;
            }

            _showStandaloneRepositoryForm = false;
            _standaloneRepoFormModel = new CreateRepositoryRequest();
            await ReloadStandaloneRepositoriesAsync();
        }
        catch (Exception ex)
        {
            _standaloneRepoError = $"创建独立仓库失败：{ex.Message}";
        }
    }

    private static string BuildRepositoryErrorMessage<T>(RepositoryMutationResult<T> result, string defaultMessage)
    {
        return result.Outcome switch
        {
            RepositoryMutationOutcome.SystemNotFound => defaultMessage,
            RepositoryMutationOutcome.RepositoryNotFound => "仓库不存在。",
            RepositoryMutationOutcome.DuplicateName => result.Message ?? "仓库名称已存在。",
            RepositoryMutationOutcome.GitAuthenticationRequired or RepositoryMutationOutcome.GitUnreachable =>
                $"Git URL 不可达：{result.Message}",
            _ => defaultMessage,
        };
    }

    private async Task<string?> ValidateRepositoryRequestAsync(CreateRepositoryRequest request)
    {
        ValidationResult validationResult = await RepositoryRequestValidator.ValidateAsync(request);
        if (validationResult.IsValid)
        {
            return null;
        }

        return validationResult.Errors.Select(error => error.ErrorMessage).FirstOrDefault();
    }

    private void OpenOwnerManagement(SystemEntity system)
    {
        _ownerManagementSystem = system;
        _showOwnerManagement = true;
    }

    private Task OnOwnerManagementVisibilityChanged(bool visible)
    {
        _showOwnerManagement = visible;

        if (!visible)
        {
            _ownerManagementSystem = null;
        }

        return Task.CompletedTask;
    }

    private async Task SaveSystemAsync()
    {
        if (_isSaving) return;

        _isSaving = true;
        _saveError = null;

        try
        {
            if (_editingSystem is null)
            {
                bool nameExists = await SystemRepository.NameExistsAsync(_formModel.Name);
                if (nameExists)
                {
                    _saveError = "系统名称已存在。";
                    _isSaving = false;
                    return;
                }

                SystemEntity newSystem = new(
                    _formModel.Name,
                    _formModel.Description,
                    _formModel.Context,
                    DateTimeOffset.UtcNow);

                await SystemRepository.AddAsync(newSystem);
                await SystemRepository.SaveChangesAsync();
            }
            else
            {
                bool nameExists = await SystemRepository.NameExistsAsync(_formModel.Name, _editingSystem.Id);
                if (nameExists)
                {
                    _saveError = "系统名称已存在。";
                    _isSaving = false;
                    return;
                }

                SystemEntity? existing = await SystemRepository.GetByIdAsync(_editingSystem.Id);
                if (existing is null)
                {
                    _saveError = "系统不存在或已被删除。";
                    _isSaving = false;
                    return;
                }

                existing.UpdateDetails(
                    _formModel.Name,
                    _formModel.Description,
                    _formModel.Context,
                    DateTimeOffset.UtcNow);

                await SystemRepository.SaveChangesAsync();
            }

            _showForm = false;
            _editingSystem = null;
            await LoadSystemsAsync();
        }
        catch (Exception ex)
        {
            _saveError = $"保存失败：{ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteSystemAsync(SystemEntity system)
    {
        _pendingDeleteSystem = system;
        _showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        _pendingDeleteSystem = null;
        _showDeleteConfirmation = false;
        _loadError = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_pendingDeleteSystem is null) return;

        SystemEntity system = _pendingDeleteSystem;
        _pendingDeleteSystem = null;
        _showDeleteConfirmation = false;

        try
        {
            SystemDeleteResult result = await SystemRepository.DeleteIfNoDependenciesAsync(system.Id);

            if (result.Outcome == SystemDeleteOutcome.Deleted)
            {
                await SystemRepository.SaveChangesAsync();
                await LoadSystemsAsync();
            }
            else if (result.Outcome == SystemDeleteOutcome.HasDependencies)
            {
                _loadError = "请先移除依赖（仓库或系统所有者分配），再删除该系统。";
            }
            else
            {
                _loadError = "系统不存在或已被删除。";
            }
        }
        catch (Exception ex)
        {
            _loadError = $"删除失败：{ex.Message}";
        }
    }

    private SystemLlmProviderOverrideSummaryDto? GetSystemOverride(Guid systemId, AgentType agentType)
    {
        if (!_systemLlmOverrides.TryGetValue(systemId, out List<SystemLlmProviderOverrideSummaryDto>? overrides))
        {
            return null;
        }

        return overrides.FirstOrDefault(item => item.AgentType == (int)agentType);
    }

    private static string GetAgentTypeDisplayName(AgentType agentType)
    {
        return agentType switch
        {
            AgentType.Orchestrator => "编排代理",
            AgentType.Worker => "工作代理",
            AgentType.Chat => "对话代理",
            _ => "未知代理",
        };
    }

    private static string GetDatabaseTypeDisplayName(int? databaseType)
    {
        if (!databaseType.HasValue || !Enum.IsDefined(typeof(DatabaseType), databaseType.Value))
        {
            return "-";
        }

        return ((DatabaseType)databaseType.Value).ToString();
    }
